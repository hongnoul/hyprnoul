// Waybar ‚ÄĒ minimal bottom bar for Hyprland (Justin)
// Icon-only: details live in hover tooltips; clicks open floating popups
// (see the "waybar-modals" window rule in hyprland.lua)
{
  "layer": "top",
  "position": "bottom",
  "height": 28,
  "spacing": 6,
  "reload_style_on_change": true,

  "modules-left":   ["hyprland/workspaces"],
  "modules-center": [],
  "modules-right":  ["tray", "custom/theme", "custom/fcitx", "bluetooth", "pulseaudio", "network", "battery", "clock"],

  "hyprland/workspaces": {
    "format": "{name}",
    "sort-by": "number",
    "on-click": "activate"
  },

  "tray": { "spacing": 8, "icon-size": 16 },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "battery": {
    "bat": "BAT1",
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon}",
    "format-icons": ["ůįĀļ", "ůįĀľ", "ůįĀĺ", "ůįāÄ", "ůįāā"],
    "format-charging": "ůįāĄ",
    "format-plugged": "ůįö•",
    "format-full": "ůįö•",
    "tooltip-format": "{capacity}% ‚ÄĒ {timeTo}",
    "tooltip-format-plugged": "{capacity}% ‚ÄĒ Not charging",
    "tooltip-format-full": "{capacity}% ‚ÄĒ Full",
    "on-click": "qs ipc call power toggle"
  },

  "network": {
    "format-wifi": "{icon}",
    "format-icons": ["ůį§Į", "ůį§ü", "ůį§Ę", "ůį§•", "ůį§®"],
    "format-ethernet": "ůįÄā",
    "format-disconnected": "ůį§ģ",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "kitty --class nmtui-float -e nmtui"
  },

  "bluetooth": {
    "format": "ůįāĮ",
    "format-disabled": "ůįā≤",
    "format-off": "ůįā≤",
    "format-connected": "ůįāĪ",
    "tooltip-format": "{controller_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "on-click": "kitty --class bluetui-float -e bluetui"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "ůįĚü",
    "format-icons": { "headphone": "ůįčč", "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"] },
    "tooltip-format": "{desc}\n{volume}%",
    "scroll-step": 5,
    "on-click": "pavucontrol"
  },

  "custom/theme": {
    "exec": "/home/hongnoul/.config/waybar/scripts/theme-toggle.sh status",
    "return-type": "json",
    "interval": "once",
    "signal": 8,
    "on-click": "/home/hongnoul/.config/waybar/scripts/theme-toggle.sh toggle"
  },

  "custom/fcitx": {
    "exec": "/home/hongnoul/.config/waybar/scripts/fcitx-indicator.sh",
    "return-type": "json",
    "on-click": "fcitx5-remote -t"
  }
}
